# ApparenceKit Environment Variables
# Copy this file to .env and fill in your values.
# These are passed to Flutter via --dart-define flags.

# Environment (dev or prod)
ENV=dev

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Backend URL (if using a custom backend, otherwise leave empty)
BACKEND_URL=

# RevenueCat (in-app purchases)
RC_ANDROID_API_KEY=
RC_IOS_API_KEY=

# Analytics
MIXPANEL_TOKEN=

# Error Reporting (prod only)
SENTRY_DSN=

# App Store (for rating prompts)
APP_STORE_ID=
