# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release


landing/dist/
landing/.firebase/
landing/node_modules/
landing/node_modules/**


.temp
**/.temp

# Compiled JavaScript files
lib/**/*.js
lib/**/*.js.map

# TypeScript v1 declaration files
firebase/functions/typings/

# Node.js dependency directory
**/node_modules/

firebase/functions/lib/

# Deno cache (Supabase Edge Functions)
/supabase/.deno_cache/
/supabase/*.lock

# Supabase local development
/supabase/.temp/

# Firebase options (generated per-project via flutterfire configure)
lib/firebase_options.dart
lib/firebase_options_dev.dart

# Firebase credentials (per-project, never share)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
ios/firebase_app_id_file.json

# Environment files (contain secrets)
.env
.env.*
!.env.example

# Generated Dart files (regenerate with: dart run build_runner build)
*.g.dart
*.freezed.dart
